/* Reseta as margens e define a cor de fundo (Dark Mode) */
body {
    background-color: #0f0f0f;
    font-family: "Roboto", Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
}

/* Container que segura o input e o botão juntos */
.search-container {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 600px;
    margin: 0 20px;
}

/* O campo de digitar */
.search-input {
    flex: 1; /* Ocupa o máximo de espaço possível */
    height: 40px;
    padding: 0 16px;
    background-color: #121212;
    border: 1px solid #303030;
    border-right: none; /* Tira a borda direita para grudar no botão */
    border-radius: 40px 0 0 40px; /* Arredonda só o lado esquerdo */
    color: white;
    font-size: 16px;
    outline: none;
}

/* Efeito quando o usuário clica para digitar */
.search-input:focus {
    border: 1px solid #1c62b9; /* Borda azul estilo YouTube */
    background-color: #0f0f0f;
}

/* O botão de lupa */
.search-button {
    height: 42px;
    width: 64px;
    background-color: #222222;
    border: 1px solid #303030;
    border-radius: 0 40px 40px 0; /* Arredonda só o lado direito */
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background-color 0.2s;
}

/* Efeito ao passar o mouse no botão */
.search-button:hover {
    background-color: #303030;
}