<!-- PLAYLIST COM CAPAS AUTOMÁTICAS (COPIAR E COLAR) -->
<!-- ======================================================= -->

<!-- 1. ESTILOS (Layout flexível para capa + texto) -->
<style>
  .container-youtube {
    display: flex;
    gap: 20px;
    background-color: #0f0f0f;
    padding: 20px;
    border-radius: 12px;
    font-family: Arial, sans-serif;
  }

  /* Player do YouTube */
  #playerYoutube {
    width: 100%;
    max-width: 640px;
    height: 360px;
    border-radius: 8px;
  }

  /* Caixa da Playlist */
  .caixa-playlist {
    background-color: #212121;
    border-radius: 12px;
    padding: 15px;
    width: 100%;
    max-width: 380px;
    max-height: 360px;
    overflow-y: auto;
    color: #ffffff;
    box-sizing: border-box;
  }

  .caixa-playlist h3 {
    margin: 0 0 12px 0;
    border-bottom: 1px solid #3d3d3d;
    padding-bottom: 10px;
    font-size: 16px;
  }

  /* Cada item da lista (Capa + Título lado a lado) */
  .item-playlist {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 8px;
    background-color: #181818;
    border-radius: 8px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .item-playlist:hover {
    background-color: #383838;
  }

  /* Destaque do vídeo que está TOCANDO AGORA */
  .item-playlist.ativo {
    background-color: #272727;
    border: 2px solid #ff0000; /* Borda vermelha */
  }

  /* Imagem da Capa (Thumbnail) */
  .capa-thumb {
    width: 120px;
    height: 68px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  /* Título ao lado da capa */
  .titulo-thumb {
    font-size: 13px;
    color: #f1f1f1;
    font-weight: 500;
    line-height: 1.3;
  }
</style>

<!-- 2. ESTRUTURA NA TELA -->
<div class="container-youtube">
  <div id="playerYoutube"></div>

  <div class="caixa-playlist">
    <h3>Playlist</h3>
    <div id="listaPlaylist"></div>
  </div>
</div>

<!-- 3. LÓGICA E CAPAS AUTOMÁTICAS -->
<script>
  const playlist = [
    { titulo: "Madness Combat 1", id: "H1aubPfepmg" },
    { titulo: "Madness Combat 2: Redeemer", id: "K9F7FKcz80k" },
    { titulo: "Madness Combat 3: Avenger", id: "2cNVaHVP6p8" }
  ];

  let player;
  let indiceAtual = 0;

  // Carrega a API do YouTube
  const tag = document.createElement('script');
  tag.src = "https://www.youtube.com/iframe_api";
  const firstScriptTag = document.getElementsByTagName('script')[0];
  firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

  // Coloque o "window." antes do nome da funcao:
  window.onYouTubeIframeAPIReady = function() {
  player = new YT.Player('playerYoutube', {
    videoId: playlist[0].id,
    events: {
      'onStateChange': quandoEstadoMudar
    }
  });
  desenharPlaylist();
};

  function onYouTubeIframeAPIReady() {
    player = new YT.Player('playerYoutube', {
      videoId: playlist[0].id,
      events: {
        'onStateChange': quandoEstadoMudar
      }
    });
    desenharPlaylist();
  }

  // Gera a lista com as CAPAS dos vídeos
  function desenharPlaylist() {
    const container = document.getElementById("listaPlaylist");
    if (!container) return;
    
    container.innerHTML = "";

    playlist.forEach((video, index) => {
      const item = document.createElement("div");
      item.className = "item-playlist" + (index === indiceAtual ? " ativo" : "");

      // Pega a capa direto dos servidores do YouTube usando o ID
      const urlCapa = `https://img.youtube.com/vi/${video.id}/mqdefault.jpg`;

      // Monta a imagem e o título juntos
      item.innerHTML = `
        <img src="${urlCapa}" alt="Capa do vídeo" class="capa-thumb">
        <span class="titulo-thumb">${video.titulo}</span>
      `;

      item.onclick = function() {
        tocarVideo(index);
      };

      container.appendChild(item);
    });
  }

  function tocarVideo(index) {
    indiceAtual = index;
    player.loadVideoById(playlist[indiceAtual].id);
    desenharPlaylist();
  }

  // Quando o vídeo acabar, pula pro próximo sozinho
  function quandoEstadoMudar(event) {
    if (event.data === YT.PlayerState.ENDED) {
      let proximo = (indiceAtual + 1) % playlist.length;
      tocarVideo(proximo);
    }
  }
</script>
